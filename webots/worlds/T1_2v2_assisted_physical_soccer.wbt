#VRML_SIM R2023b utf8

EXTERNPROTO "webots://projects/objects/backgrounds/protos/TexturedBackgroundLight.proto"
EXTERNPROTO "webots://projects/objects/backgrounds/protos/TexturedBackground.proto"

WorldInfo {
  basicTimeStep 16
  FPS 30
  contactProperties [
    ContactProperties { material1 "foot_contact" material2 "default" coulombFriction [ 1.2 ] bounce 0.02 }
    ContactProperties { coulombFriction [ 1.2 ] bounce 0.0 }
  ]
}
Viewpoint {
  orientation 0.45 0.16 -0.88 2.34
  position 0.0 4.2 4.2
  follow "SOCCER_BALL"
}
TexturedBackground { texture "empty_office" }
TexturedBackgroundLight { }

# === Formal soccer field texture; collision remains the original flat Box ===
Solid {
  translation 0 0 -0.005
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 1 1 1
        baseColorMap ImageTexture {
          url [
            "../textures/formal_soccer_field.png"
          ]
        }
        roughness 0.9
        metalness 0
      }
      geometry IndexedFaceSet {
        coord Coordinate {
          point [
            -3.5 -2.5 0.0055
             3.5 -2.5 0.0055
             3.5  2.5 0.0055
            -3.5  2.5 0.0055
          ]
        }
        texCoord TextureCoordinate {
          point [
            0 0
            1 0
            1 1
            0 1
          ]
        }
        coordIndex [
          0 1 2 3 -1
        ]
        texCoordIndex [
          0 1 2 3 -1
        ]
      }
    }
  ]
  name "green_field"
  boundingObject Box { size 7 5 0.01 }
}

DEF SOCCER_BALL Solid {
  translation -0.80 -0.35 0.112
  rotation 0 0 1 0
  children [ Shape { appearance PBRAppearance { baseColor 1 1 1 roughness 0.2 metalness 0 } geometry Sphere { radius 0.11 } } ]
  name "soccer_ball"
  boundingObject Sphere { radius 0.11 }
  physics Physics {
    density -1
    mass 0.43
    damping Damping { linear 1.0 angular 1.0 }
  }
}

DEF BLUE_GOAL Solid {
  translation -3.3 0.0 0.3
  children [ Shape { appearance PBRAppearance { baseColor 0 0 1 } geometry Box { size 0.1 1.5 0.6 } } ]
  name "blue_goal"
  boundingObject Box { size 0.1 1.5 0.6 }
}
DEF RED_GOAL Solid {
  translation 3.3 0.0 0.3
  children [ Shape { appearance PBRAppearance { baseColor 1 0 0 } geometry Box { size 0.1 1.5 0.6 } } ]
  name "red_goal"
  boundingObject Box { size 0.1 1.5 0.6 }
}

Robot { translation 0 0 0 name "four_robot_match_supervisor" controller "four_robot_match_supervisor" supervisor TRUE }
Robot { translation 0 0 0 name "match_state_monitor" controller "match_state_monitor" supervisor TRUE }

